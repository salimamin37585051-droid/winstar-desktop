{
  "name": "winstar",
  "version": "2.0.0",
  "description": "Winstar Uniform Inventory Management System",
  "main": "main.js",
  "author": "Winstar",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "co.ke.winstar.app",
    "productName": "Winstar",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "index.html"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    }
  }
}
